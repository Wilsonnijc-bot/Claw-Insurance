#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
case "$SCRIPT_PATH" in
  */*) SCRIPT_DIR="${SCRIPT_PATH%/*}" ;;
  *) SCRIPT_DIR="." ;;
esac
ROOT_DIR="$(cd -- "$SCRIPT_DIR" && pwd -P)"

print_step() {
  printf '\n[%s] %s\n' "$1" "$2"
}

fail() {
  printf 'docker-up: %s\n' "$1" >&2
  exit 1
}

need_command() {
  local name="$1"
  local guidance="$2"
  if ! command -v "$name" >/dev/null 2>&1; then
    fail "$name not found. $guidance"
  fi
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOF'
Usage: ./docker-up [SERVICE...]

Runs Docker host preflight, prepares macOS WhatsApp sync dependencies when applicable,
and then starts the local stack with:
  docker compose up -d --build [SERVICE...]
EOF
  exit 0
fi

need_command "docker" "Install Docker Desktop or another Docker engine with Compose support."
if ! docker compose version >/dev/null 2>&1; then
  fail "docker compose is not available. Update Docker so Compose v2 is installed."
fi

export WEB_BROWSER_MODE="${WEB_BROWSER_MODE:-cdp}"
export WEB_CDP_URL="${WEB_CDP_URL:-http://host.docker.internal:9222}"
export WEB_HOST_PROFILE_DIR="${WEB_HOST_PROFILE_DIR:-$ROOT_DIR/whatsapp-web}"
export WEB_HISTORY_SYNC_ENABLED="${WEB_HISTORY_SYNC_ENABLED:-true}"
mkdir -p "$WEB_HOST_PROFILE_DIR"

case "$(uname -s)" in
  Darwin)
    need_command "python3" "Install Python 3 and rerun ./docker-up."
    print_step "1/3" "Checking macOS Chrome/CDP prerequisites"
    if ! (
      cd "$ROOT_DIR" &&
      python3 - <<'PY'
from nanobot.macos_cdp_helper import resolve_chrome_path
resolve_chrome_path()
PY
    ) >/dev/null 2>&1; then
      fail "No supported Chrome/Chromium executable was found on this Mac. Install Chrome/Chromium, or set WEB_CDP_CHROME_PATH before running ./docker-up."
    fi

    export WEB_CDP_HELPER_URL="${WEB_CDP_HELPER_URL:-http://host.docker.internal:9230}"
    if ! (cd "$ROOT_DIR" && python3 -m nanobot.macos_cdp_helper health >/dev/null 2>&1); then
      print_step "2/3" "Installing macOS CDP helper"
      (cd "$ROOT_DIR" && python3 -m nanobot.macos_cdp_helper install)
    else
      print_step "2/3" "macOS CDP helper already healthy"
    fi
    final_step="3/3"
    ;;
  *)
    print_step "1/2" "Non-macOS host detected"
    export WEB_HISTORY_SYNC_ENABLED="false"
    export WEB_CDP_HELPER_URL=""
    printf '%s\n' \
      "Docker startup is supported on this host, but WhatsApp history sync is not prepared here." \
      "The app will start normally with sync disabled."
    final_step="2/2"
    ;;
esac

print_step "${final_step:-3/3}" "Starting Docker services"
cd "$ROOT_DIR"
docker compose up -d --build "$@"
