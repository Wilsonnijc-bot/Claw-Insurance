# IMPORTANT: Do NOT put real secret keys into the repository.
# Copy this file to `.env` on the server and fill real values there.
# Example: cp .env.example .env && edit .env

# LiteLLM keys (keep private on the server)
MOONSHOT_API_KEY=sk-...
LITELLM_MASTER_KEY=sk-...
LITELLM_DB_PASSWORD=change-this-strong-password

# Supabase (service role) — keep secret, used only by db-proxy on the server
# SUPABASE_URL should look like: https://<project>.supabase.co
SUPABASE_URL=https://your-supabase.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Strong random key used by NanoBot to call db-proxy
DB_PROXY_API_KEY=your-db-proxy-child-key

# Interview proxy key and Google creds (keep private on the server)
INTERVIEW_PROXY_API_KEY=your-interview-proxy-child-key
# Place your Google service account JSON at ./secrets/google.json (will be mounted read-only by docker-compose)
GOOGLE_CREDENTIAL_JSON_PATH=/secrets/google.json

# Notes:
# - Never commit the `.env` file with real keys. Add `.env` to .gitignore (already added in this folder).
# - Use the server's environment or a protected secrets store for production deployments.
